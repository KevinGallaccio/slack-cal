{
  "name": "slack-cal",
  "version": "0.1.0",
  "description": "Auto-update your Slack status from Google Calendar events, with Claude Haiku 4.5 classification.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "auth": "tsx src/scripts/auth.ts",
    "bootstrap": "tsx src/scripts/bootstrap.ts",
    "migrate": "tsx src/scripts/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@fastify/formbody": "^8.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "google-auth-library": "^9.14.0",
    "googleapis": "^144.0.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
